	$(BB_CDLL_OBJ_DIR)/voice_status.o \

DLL_OBJS = \
	$(BB_SERVER_OBJ_DIR)/bb_wpn_flame.o \
	$(BB_SERVER_OBJ_DIR)/bb_wpn_hand.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_ak47.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_benelli.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_beretta.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_beretta_a.o \
