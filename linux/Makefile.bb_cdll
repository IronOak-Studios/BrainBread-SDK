	$(BB_SERVER_OBJ_DIR)/pe_wpn_minigun.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_mp5_10.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_p225.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_sig550.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_spas12.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_stoner.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_tavor.o \
	$(BB_SERVER_OBJ_DIR)/pe_wpn_usp.o \

PUBLIC_OBJS = \
	$(PUBLIC_OBJ_DIR)/interface.o \

COMMON_OBJS = \
	$(COMMON_OBJ_DIR)/parsemsg.o \

GAME_SHARED_OBJS = \
	$(GAME_SHARED_OBJ_DIR)/vgui_checkbutton2.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_grid.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_helpers.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_listbox.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_loadtga.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_scrollbar2.o \
	$(GAME_SHARED_OBJ_DIR)/vgui_slider2.o \
	$(GAME_SHARED_OBJ_DIR)/voice_banmgr.o \
	$(GAME_SHARED_OBJ_DIR)/voice_vgui_tweakdlg.o \

PM_SHARED_OBJS = \
	$(PM_SHARED_OBJ_DIR)/pm_debug.o \
	$(PM_SHARED_OBJ_DIR)/pm_shared.o \
	$(PM_SHARED_OBJ_DIR)/pm_math.o \


all: $(BUILD_DIR)/client.$(SHLIBEXT)

$(BUILD_DIR)/client.$(SHLIBEXT): $(BB_CDLL_OBJS) $(PUBLIC_OBJS) $(COMMON_OBJS) $(GAME_SHARED_OBJS) $(DLL_OBJS) $(PM_SHARED_OBJS)
	$(CLINK) -o $@ $(BB_CDLL_OBJS) $(PUBLIC_OBJS) $(COMMON_OBJS) $(GAME_SHARED_OBJS) $(DLL_OBJS) $(PM_SHARED_OBJS) $(LDFLAGS) $(CPP_LIB)
	mkdir -p $(BB_OUTPUT_DIR)/cl_dlls
	$(P4_EDIT_START) $(BB_OUTPUT_DIR)/cl_dlls/client.$(SHLIBEXT) $(P4_EDIT_END)
	cp $@  $(BB_OUTPUT_DIR)/cl_dlls
	./gendbg.sh $(BB_OUTPUT_DIR)/cl_dlls/client.$(SHLIBEXT)

$(BB_CDLL_OBJ_DIR):
	mkdir -p $(BB_CDLL_OBJ_DIR)
	mkdir -p $(BB_CDLL_OBJ_DIR)/hl

$(BB_SERVER_OBJ_DIR):
	mkdir -p $(BB_SERVER_OBJ_DIR)

$(PUBLIC_OBJ_DIR):
	mkdir -p $(PUBLIC_OBJ_DIR)

$(COMMON_OBJ_DIR):
	mkdir -p $(COMMON_OBJ_DIR)

$(GAME_SHARED_OBJ_DIR):
	mkdir -p $(GAME_SHARED_OBJ_DIR)

$(PM_SHARED_OBJ_DIR):
	mkdir -p $(PM_SHARED_OBJ_DIR)

$(BB_CDLL_OBJ_DIR)/%.o: $(HL_SRC_DIR)/%.cpp $(filter-out $(wildcard  $(BB_CDLL_OBJ_DIR)),  $(BB_CDLL_OBJ_DIR))
	$(DO_CC)

$(BB_SERVER_OBJ_DIR)/%.o: $(HL_SERVER_SRC_DIR)/%.cpp $(filter-out $(wildcard  $(BB_SERVER_OBJ_DIR)),  $(BB_SERVER_OBJ_DIR))
	$(DO_CC)

$(BB_CDLL_OBJ_DIR)/%.o: $(HL_SRC_DIR)/hl/%.cpp $(filter-out $(wildcard  $(BB_CDLL_OBJ_DIR)),  $(BB_CDLL_OBJ_DIR))
	$(DO_CC)

$(PUBLIC_OBJ_DIR)/%.o : $(PUBLIC_SRC_DIR)/%.cpp $(filter-out $(wildcard  $(PUBLIC_OBJ_DIR)),  $(PUBLIC_OBJ_DIR))
	$(DO_PUBLIC_CC)

$(COMMON_OBJ_DIR)/%.o : $(COMMON_SRC_DIR)/%.cpp $(filter-out $(wildcard  $(COMMON_OBJ_DIR)),  $(COMMON_OBJ_DIR))
	$(DO_COMMON_CC)

$(GAME_SHARED_OBJ_DIR)/%.o : $(GAME_SHARED_SRC_DIR)/%.cpp $(filter-out $(wildcard  $(GAME_SHARED_OBJ_DIR)),  $(GAME_SHARED_OBJ_DIR))
	$(DO_COMMON_CC)

$(PM_SHARED_OBJ_DIR)/%.o : $(PM_SHARED_SRC_DIR)/%.c $(filter-out $(wildcard  $(PM_SHARED_OBJ_DIR)),  $(PM_SHARED_OBJ_DIR))
	$(DO_PM_SHARED_CC)

# Pull in auto-generated header dependencies (silently ignored on first build)
-include $(BB_CDLL_OBJS:.o=.d)
-include $(DLL_OBJS:.o=.d)
-include $(PUBLIC_OBJS:.o=.d)
-include $(COMMON_OBJS:.o=.d)
-include $(GAME_SHARED_OBJS:.o=.d)
-include $(PM_SHARED_OBJS:.o=.d)

clean:
	-rm -rf $(BB_CDLL_OBJ_DIR)
	-rm -f client.$(SHLIBEXT)
