	$(BB_CDLL_OBJ_DIR)/vgui_equip.o \
	$(BB_CDLL_OBJ_DIR)/vgui_MOTDWindow.o \
	$(BB_CDLL_OBJ_DIR)/vgui_SchemeManager.o \
	$(BB_CDLL_OBJ_DIR)/vgui_ScorePanel.o \
	$(BB_CDLL_OBJ_DIR)/vgui_SummaryPanel.o \
	$(BB_CDLL_OBJ_DIR)/vgui_ServerBrowser.o \
